{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "white": "#FFFFFF",
    "tan": "#CC3802",
    "teal": "#047E84",
    "plum": "#9A348E",
    "blush": "#DA627D",
    "salmon": "#FCA17D",
    "sky": "#86BBD8",
    "teal_blue": "#33658A",
    "light_teal_blue": "#4C7A9B",
    "black": "#000000",
    "orange": "#F07623",
    "blue": "#4B95E9",
    "green": "#59C9A5",
    "orange": "#F07623",
    "red": "#D81E5B",
    "white": "#E0DEF4",
    "yellow": "#F3AE35",
    "lavender": "#ffb86c"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "foreground": "p:white",
          "background": "p:tan",
          "template": "{{ if .Env.PNPPSHOST }} \uf8c5 {{ .Env.PNPPSHOST }} {{ end }}"
        },
        {
          "type": "text",
          "style": "powerline",
          "foreground": "p:white",
          "background": "p:teal",
          "powerline_symbol": "\ue0b0",
          "template": "{{ if .Env.PNPPSSITE }} \uf2dd {{ .Env.PNPPSSITE }}{{ end }}"
        },
        {
          "type": "text",
          "style": "diamond",
          "trailing_diamond": "\ue0b4",
          "foreground": "p:white",
          "background": "p:teal",
          "template": "{{ if .Env.PNPPSSITE }}\u00A0{{ end }}"
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:plum",
          "foreground": "p:white",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "style": "diamond",
          "template": "{{ .UserName }} ",
          "type": "session"
        },
        {
          "background": "p:blush",
          "foreground": "p:white",
          "powerline_symbol": "\ue0b0",
          "options": {
            "style": "folder"
          },
          "style": "powerline",
          "template": " \uea83 {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "p:salmon",
          "foreground": "p:black",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": "\u200a",
          "type": "text"
        },
        {
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "foreground": "p:black",
          "background": "p:salmon",
          "powerline_symbol": "\ue0b0",
          "type": "git",
          "style": "powerline",
          "template": "{{ if .UpstreamURL }}{{ url .UpstreamIcon .UpstreamURL }} {{ end }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }} "
        },
        {
          "background": "p:sky",
          "foreground": "p:black",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": "\u200a",
          "type": "text"
        },
        {
          "background": "p:sky",
          "foreground": "p:black",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": "{{ if .SSHSession }}\uf817 SSH {{ end }}",
          "type": "session"
        },
        {
          "background": "#1ABC9C",
          "foreground": "p:black",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": "\u200a",
          "type": "text"
        },
        {
        "background": "#1ABC9C",
        "foreground": "p:black",
        "powerline_symbol": "\ue0b0",
        "style": "powerline",
        "template": "{{ if .Env.VIRTUAL_ENV }}\ue235 {{ base .Env.VIRTUAL_ENV }} {{ end }}",
        "type": "python"
        },
        {
          "background": "p:teal_blue",
          "foreground": "p:white",
          "options": {
            "time_format": "15:04"
          },
          "style": "diamond",
          "template": " \u2665 {{ .CurrentDate | date .Format }} ",
          "trailing_diamond": "\ue0b0",
          "type": "time"
        },
        {
          "options": {
            "always_enabled": true
          },
          "leading_diamond": "<transparent,background>\ue0b0</>",
          "trailing_diamond": "\ue0b4",
          "template": " {{ if gt .Code 0 }}\uf00d{{ else }}\uf00c{{ end }} ",
          "foreground": "p:black",
          "background": "#5DADE2",
          "type": "status",
          "style": "diamond",
          "background_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ]
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
